# Copy to .env and fill in. Never commit the real .env (it is gitignored).

# --- dataovozidlech.cz live API (fallback when the cache misses) ---
API_KEY=
API_BASE_URL=https://api.dataovozidlech.cz/api/vehicletechnicaldata/v2

# --- Auth ---
JWT_SECRET=

# --- Vercel Postgres (users, vehicles, reminders, certificates) ---
POSTGRES_URL=

# --- Scaleway registry cache (read-only lookup path) ---
VEHICLE_CACHE_DATABASE_URL=

# --- Email (Resend) ---
RESEND_API_KEY=

# --- Cron ---
CRON_SECRET=

# --- Certificate sales (Lemon Squeezy — Merchant of Record, handles EU VAT) ---
# Store + variant ids are the SAME in test and live (test is a store-wide toggle).
# Store id (Settings > Stores, the numeric id).
LEMONSQUEEZY_STORE_ID=
# Variant id of the certificate product (priced 99 Kč CZK, tax-inclusive).
LEMONSQUEEZY_VARIANT_ID=
# API key + webhook secret DIFFER by mode. Outside production the code prefers the
# *_TEST values (falls back to the base name); production uses the base (live) name.
LEMONSQUEEZY_API_KEY_TEST=
LEMONSQUEEZY_WEBHOOK_SECRET_TEST=
# Live values — set these in Vercel production env (NODE_ENV=production).
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_WEBHOOK_SECRET=
# Display price in whole crowns, VAT-inclusive (default 99). Must match the Lemon
# Squeezy variant price and CERTIFICATE_PRICE_CZK in src/components/VehicleInfo.tsx.
CERTIFICATE_PRICE_CZK=99
# Public site origin for success/verify/download links (no trailing slash).
PUBLIC_BASE_URL=https://vininfo.cz

# --- Runtime ---
NODE_ENV=development
