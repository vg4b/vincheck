# Local dev server settings (react-scripts start). NOT read by the production
# build on Vercel, so it can't affect deploys.

# CRA bundles ESLint (eslint-config-react-app); under pnpm's nested module layout
# it resolves to two paths and throws "Plugin react was conflicted between ...",
# breaking `pnpm start`. We lint with biome (`pnpm lint`/`pnpm check`), so the
# webpack ESLint plugin is redundant — disable it to unblock the dev server.
DISABLE_ESLINT_PLUGIN=true
