{
	"functions": {
		"api/**/*.ts": {
			"includeFiles": "api/_fonts/**"
		}
	},
	"trailingSlash": false,
	"rewrites": [
		{
			"source": "/api/(.*)",
			"destination": "/api/$1"
		},
		{
			"source": "/znacky-sitemap.xml",
			"destination": "/api/stats?type=sitemap"
		},
		{
			"source": "/((?!api/|znacky-sitemap.xml|seznam-wmt-|static/|logos/|favicon.ico|manifest.json|logo192.png|logo512.png|robots.txt|asset-manifest.json|site.webmanifest|sitemap.xml|certificate-preview.png).*)",
			"destination": "/index.html"
		}
	],
	"headers": [
		{
			"source": "/api/(.*)",
			"headers": [
				{
					"key": "Access-Control-Allow-Methods",
					"value": "GET, OPTIONS"
				}
			]
		},
		{
			"source": "/logo-email.png",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=31536000, immutable"
				}
			]
		},
		{
			"source": "/favicon.svg",
			"headers": [
				{ "key": "Cache-Control", "value": "public, max-age=604800, must-revalidate" }
			]
		},
		{
			"source": "/favicon.ico",
			"headers": [
				{ "key": "Cache-Control", "value": "public, max-age=604800, must-revalidate" }
			]
		},
		{
			"source": "/favicon-96x96.png",
			"headers": [
				{ "key": "Cache-Control", "value": "public, max-age=604800, must-revalidate" }
			]
		},
		{
			"source": "/apple-touch-icon.png",
			"headers": [
				{ "key": "Cache-Control", "value": "public, max-age=604800, must-revalidate" }
			]
		},
		{
			"source": "/web-app-manifest-192x192.png",
			"headers": [
				{ "key": "Cache-Control", "value": "public, max-age=604800, must-revalidate" }
			]
		},
		{
			"source": "/web-app-manifest-512x512.png",
			"headers": [
				{ "key": "Cache-Control", "value": "public, max-age=604800, must-revalidate" }
			]
		}
	],
	"crons": [
		{
			"path": "/api/cron/send-reminders",
			"schedule": "0 8 * * *"
		}
	]
}
