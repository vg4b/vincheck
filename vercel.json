{
	"rewrites": [
		{
			"source": "/api/(.*)",
			"destination": "/api/$1"
		},
		{
			"source": "/((?!api/|static/|logos/|favicon.ico|manifest.json|logo192.png|logo512.png|robots.txt|asset-manifest.json|site.webmanifest|sitemap.xml).*)",
			"destination": "/index.html"
		}
	],
	"headers": [
		{
			"source": "/api/(.*)",
			"headers": [
				{
					"key": "Access-Control-Allow-Methods",
					"value": "GET, OPTIONS"
				}
			]
		},
		{
			"source": "/logo-email.png",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=31536000, immutable"
				}
			]
		},
		{
			"source": "/(favicon\\.(svg|ico)|favicon-96x96\\.png|apple-touch-icon\\.png|web-app-manifest-(192x192|512x512)\\.png)",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=604800, must-revalidate"
				}
			]
		}
	],
	"crons": [
		{
			"path": "/api/cron/send-reminders",
			"schedule": "0 8 * * *"
		}
	]
}
